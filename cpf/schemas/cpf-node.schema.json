{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CPF Unified Node",
  "type": "object",
  "required": [
    "node_id",
    "node_type",
    "status",
    "version",
    "locked",
    "payload"
  ],
  "properties": {
    "node_id": {
      "type": "string"
    },
    "node_type": {
      "enum": [
        "story",
        "plot",
        "chapter",
        "map",
        "boss",
        "character",
        "section",
        "event",
        "milestone"
      ]
    },
    "status": {
      "enum": [
        "DRAFT",
        "REVIEW",
        "APPROVED",
        "LOCKED",
        "REJECTED",
        "SUPERSEDED",
        "ARCHIVED"
      ]
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "locked": {
      "type": "boolean"
    },
    "manual_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rule_version": {
      "type": "string"
    },
    "generator_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "generator_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_node_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
