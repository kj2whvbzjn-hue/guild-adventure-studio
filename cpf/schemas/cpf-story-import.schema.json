{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gk-studio.local/schemas/cpf-story-import.schema.json",
  "title": "CPF Story Import",
  "type": "object",
  "required": ["title", "chapters"],
  "additionalProperties": true,
  "properties": {
    "story_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$", "maxLength": 80},
    "title": {"type": "string", "minLength": 1, "maxLength": 200},
    "premise": {"type": "string", "maxLength": 20000},
    "summary": {"type": "string", "maxLength": 20000},
    "themes": {"type": "array", "maxItems": 100, "items": {"type": "string", "maxLength": 500}},
    "ending_goal": {"type": "string", "maxLength": 5000},
    "source_format": {"type": "string", "maxLength": 100},
    "chapters": {
      "type": "array", "minItems": 1, "maxItems": 20,
      "items": {
        "type": "object", "required": ["title"], "additionalProperties": true,
        "properties": {
          "chapter_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$", "maxLength": 80},
          "order": {"type": "integer", "minimum": 1, "maximum": 20},
          "chapter_no": {"type": "integer", "minimum": 1, "maximum": 20},
          "title": {"type": "string", "minLength": 1, "maxLength": 200},
          "theme": {"type": "string", "maxLength": 2000},
          "summary": {"type": "string", "maxLength": 20000},
          "milestones": {"type": "array", "maxItems": 100},
          "locked_fields": {"type": "array", "maxItems": 100, "items": {"type": "string", "maxLength": 100}}
        }
      }
    }
  }
}
