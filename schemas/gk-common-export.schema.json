{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gk-common-export.schema.json",
  "title": "GK Studio Common Export",
  "type": "object",
  "required": [
    "schema_version",
    "data_version",
    "generated_at",
    "generated_by",
    "data"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+"
    },
    "data_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generated_by": {
      "type": "string"
    },
    "data": {}
  },
  "additionalProperties": false
}