{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/exports/ai-ai_nodes.schema.json",
  "title": "ai/ai_nodes.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id"
    ],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "node_type": {
        "type": "string",
        "enum": [
          "condition",
          "target",
          "action"
        ]
      }
    },
    "additionalProperties": true
  }
}
